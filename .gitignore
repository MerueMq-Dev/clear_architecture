```gitignore
# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / build
build/
dist/
*.egg-info/
*.egg

# Logs
*.log

# Environment variables
.env
.env.*
!.env.example

# SQLite (если используешь)
*.sqlite3

# Test / coverage
.pytest_cache/
.coverage
htmlcov/

# Type checkers / linters
.mypy_cache/
.ruff_cache/

# Jupyter (если вдруг используешь)
.ipynb_checkpoints/

# IDE / editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Vim / Emacs
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
Desktop.ini
```
